# lab.env — cluster-specific configuration sourced by every lab_*.sh script.
# Adjust each value to match your environment, then commit. Do NOT put secrets here.

# ---------- Orchestrator ----------
ORCHESTRATOR_NAME="autoresearch"
ORCHESTRATOR_IMAGE="research-orchestrator:latest"
# Host on which the orchestrator container actually runs (where you SSH and execute start_orchestrator.sh).
# Leave empty if the orchestrator runs on the same machine as your shell.
CONTROL_SERVER=""

# ---------- Servers (whitespace-separated; first one is the default for dispatch) ----------
LAB_SERVERS="saitou saitou-h200"

# Per-server config. For each server NAME above, define LAB_<NAME>_*:
#   _HOST       SSH alias or hostname (must work passwordlessly with the keys mounted into the orchestrator)
#   _GPUS       Number of GPUs available to you on that server
#   _GPU_MODEL  Free-text label, e.g. "A100-40GB" or "H200-144GB"
#   _WORKSPACE  Absolute path on that server's host filesystem that resolves to the SHARED NFS workspace
#   _NOTES      One-line free-text guidance the agent should consider when picking this server

LAB_saitou_HOST="saitou"
LAB_saitou_GPUS=8
LAB_saitou_GPU_MODEL="A100-40GB"
LAB_saitou_WORKSPACE="/h200-home/nonaka/research"
LAB_saitou_NOTES="8 devices x 40GB = 320GB total VRAM, but only realized via multi-GPU-aware libs (FSDP, DeepSpeed, DDP, Megatron, vLLM TP). Pick this for parallel sweeps and distributed training."

LAB_saitou_h200_HOST="saitou-h200"
LAB_saitou_h200_GPUS=1
LAB_saitou_h200_GPU_MODEL="H200-144GB"
LAB_saitou_h200_WORKSPACE="/home/nonaka/research"
LAB_saitou_h200_NOTES="Single H200 NVL with ~144GB. No sharding/NCCL needed - vanilla model.cuda() gets the full memory. Pick this when the library lacks mature multi-GPU support, or when you want the simplest training loop possible."

# ---------- Shared workspace (orchestrator-side path) ----------
# The path inside the orchestrator container where the workspace is mounted.
# Always /workspace by convention.
IN_CONTAINER_WORKSPACE="/workspace"

# Path on the orchestrator's HOST filesystem where the shared NFS workspace is mounted.
# This is what gets bind-mounted into the orchestrator container.
ORCHESTRATOR_WORKSPACE_HOST_PATH="/h200-home/nonaka/research"

# Additional bind mounts for the orchestrator container (host:container, comma-separated).
# Typical: HuggingFace cache, checkpoints, large datasets.
ORCHESTRATOR_EXTRA_MOUNTS="\
/h200-home/nonaka/checkpoints:/checkpoints,\
/h200-home/nonaka/hf_cache:/root/.cache/huggingface,\
/data2/nonaka:/data2"

# ---------- Resource policy ----------
# Maximum number of concurrent workers per server. Use 1 if you must serialize (e.g. shared device).
LAB_MAX_CONCURRENT_saitou=4
LAB_MAX_CONCURRENT_saitou_h200=1

# Memory threshold (MiB) below which a GPU counts as "busy" when picking free GPUs.
GPU_BUSY_FREE_MIB_THRESHOLD=2000

# ---------- Auth ----------
# Path on the host (control server) where Claude Code stores its credentials.
# Bind-mounted into the orchestrator so Claude reuses your existing login.
HOST_CLAUDE_DIR="$HOME/.claude"

# Path on the host to ssh keys + config used to reach OTHER servers.
# Bind-mounted read-only into the orchestrator.
HOST_SSH_DIR="$HOME/.ssh"

# Optional: override the Anthropic API key. Leave empty to fall back to the
# credentials in $HOST_CLAUDE_DIR (your claude.ai login).
ANTHROPIC_API_KEY=""
